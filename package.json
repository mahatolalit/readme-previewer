{
  "name": "readme-previewer",
  "displayName": "Readme Previewer – Markdown Preview for VS Code",
  "description": "Preview README.md files inside VSCode",
  "version": "1.2.0",
  "publisher": "mahatolalit",
  "engines": {
    "vscode": "^1.90.0"
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "audit": "npm audit --audit-level=high"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./extension.js",
  "icon": "media/images/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "readmePreview.showPreview",
        "title": "Preview README"
      }
    ]
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "marked-highlight": "^2.1.2",
    "node-emoji": "^2.1.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mahatolalit/readme-previewer.git"
  },
  "bugs": {
    "url": "https://github.com/mahatolalit/readme-previewer/issues"
  },
  "homepage": "https://github.com/mahatolalit/readme-previewer#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/vscode": "~1.90.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4"
  }
}
